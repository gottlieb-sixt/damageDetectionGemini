# ─────────────────────────────────────────────────────────
*.iml
.gradle/
**/.gradle/
build/
**/build/
captures/
.externalNativeBuild/
.cxx/
output.json
release/

# Android-Studio / IntelliJ
.idea/
*.iws
*.ipr

# APK / Bundle outputs
*.apk
*.aab
*.ap_
*.dex

# Keystores (NEVER commit)
*.jks
*.keystore

# Android navigation
.navigation/

